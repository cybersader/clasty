{
  "name": "obsidian-crdt-sync",
  "version": "0.1.0",
  "description": "Conflict-free sync for shared vaults using CRDT",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "crdt",
    "sync",
    "collaboration"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.10.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "0.19.8",
    "obsidian": "latest",
    "tslib": "2.6.2",
    "typescript": "5.3.2"
  },
  "dependencies": {
    "diff-match-patch": "^1.0.5",
    "lib0": "^0.2.88",
    "y-protocols": "^1.0.6",
    "yjs": "^13.6.10"
  }
}
